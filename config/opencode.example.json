{
  "mcp": {
    "research_memory": {
      "enabled": true,
      "type": "local",
      "command": [
        "node",
        "/ABSOLUTE/PATH/TO/research-memory-protocol-template/mcp/research-memory-mcp.mjs"
      ],
      "environment": {
        "RESEARCH_MEMORY_ROOT": "/ABSOLUTE/PATH/TO/YOUR/Obsidian Vault/research-memory-vault",
        "RESEARCH_MEMORY_BOOTSTRAP": "/ABSOLUTE/PATH/TO/.research-memory/BOOTSTRAP.md"
      }
    }
  }
}
